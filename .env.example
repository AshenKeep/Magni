# ============================================================
# Magni v0.0.5 — environment configuration
# Copy to .env and fill in every value before running.
# Never commit .env to Git — it is in .gitignore.
# ============================================================

# --- App URL (HTTPS required) ---
APP_URL=https://gym.yourdomain.com                  # CHANGE
ALLOWED_ORIGINS=https://gym.yourdomain.com          # CHANGE

# --- PostgreSQL ---
POSTGRES_DB=magni
POSTGRES_USER=magni
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password      # CHANGE

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_redis_password             # CHANGE

# --- FastAPI ---
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_64_char_hex_string  # CHANGE
ENVIRONMENT=production

# --- Port ---
BACKEND_PORT=8000

# --- Timezone ---
# Examples: Australia/Perth, Europe/London, America/New_York
TZ=UTC                                              # CHANGE

# --- Backup (CIFS NAS share) ---
BACKUP_SCHEDULE=0 2 * * *
BACKUP_DIR=/backups
CIFS_PATH=//YOUR_NAS_IP/backups                     # CHANGE
CIFS_USERNAME=your_nas_username                     # CHANGE
CIFS_PASSWORD=your_nas_password                     # CHANGE

# --- AscendAPI (ExerciseDB) — exercise seeding ---
# Sign up free at https://rapidapi.com
# Subscribe to "EDB with Videos and Images by AscendAPI" (Basic plan, free)
# Get your X-RapidAPI-Key from the API playground under the App tab
ASCENDAPI_KEY=CHANGE_ME_your_rapidapi_key           # CHANGE

# --- Media storage — exercise GIF caching ---
# Options:
#   external  = use AscendAPI CDN links (no downloads, default)
#   local     = download GIFs to a local Docker volume
#   cifs      = download GIFs to a CIFS NAS share
MEDIA_STORAGE=external

# Required when MEDIA_STORAGE=local:
# (no extra config needed — uses a local Docker volume automatically)

# Required when MEDIA_STORAGE=cifs:
MEDIA_CIFS_PATH=//YOUR_NAS_IP/media                 # CHANGE if using cifs
MEDIA_CIFS_USERNAME=your_nas_username               # CHANGE if using cifs
MEDIA_CIFS_PASSWORD=your_nas_password               # CHANGE if using cifs

# Docker volume type/device/options — set these to match MEDIA_STORAGE:
#   external or local:  leave as defaults below
#   cifs:               set MEDIA_VOLUME_TYPE=cifs, MEDIA_VOLUME_DEVICE=//NAS_IP/media
#                       MEDIA_VOLUME_OPTIONS=username=X,password=Y,uid=1000,gid=1000
MEDIA_VOLUME_TYPE=none
MEDIA_VOLUME_DEVICE=
MEDIA_VOLUME_OPTIONS=bind
