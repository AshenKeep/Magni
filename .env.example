# ============================================================
# Magni v0.0.6 — environment configuration
# Copy to .env and fill in every value before running.
# Never commit .env to Git — it is in .gitignore.
# ============================================================

# --- App URL (HTTPS required) ---
APP_URL=https://gym.yourdomain.com                  # CHANGE
ALLOWED_ORIGINS=https://gym.yourdomain.com          # CHANGE

# --- PostgreSQL ---
POSTGRES_DB=magni
POSTGRES_USER=magni
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password      # CHANGE

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_redis_password             # CHANGE

# --- FastAPI ---
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_64_char_hex_string  # CHANGE
ENVIRONMENT=production

# --- Port ---
BACKEND_PORT=8000

# --- Timezone ---
# Examples: Australia/Perth, Europe/London, America/New_York
TZ=UTC                                              # CHANGE

# --- Backup ---
# Cron schedule for automated backups (default: 2am daily)
BACKUP_SCHEDULE=0 2 * * *
# CIFS NAS share where backups are written
CIFS_PATH=//YOUR_NAS_IP/backups                     # CHANGE
CIFS_USERNAME=your_nas_username                     # CHANGE
CIFS_PASSWORD=your_nas_password                     # CHANGE


# --- Media storage — exercise GIF caching ---
# Options:
#   external  = use AscendAPI CDN links only (default, no downloads)
#   local     = download GIFs to local Docker volume (no extra config needed)
#   cifs      = download GIFs to CIFS NAS share (set MEDIA_CIFS_* below)
MEDIA_STORAGE=external

# Required only when MEDIA_STORAGE=cifs
# Also uncomment the cifs media_data block in docker-compose.yml
MEDIA_CIFS_PATH=//YOUR_NAS_IP/media                 # CHANGE if using cifs
MEDIA_CIFS_USERNAME=your_nas_username               # CHANGE if using cifs
MEDIA_CIFS_PASSWORD=your_nas_password               # CHANGE if using cifs

# ============================================================
# Note: Exercise API keys (AscendAPI, WorkoutX) are NOT in this file.
# They are stored in the database and managed via Admin → API Keys
# in the web UI. This was changed in v0.0.6 to make key management
# easier and more secure.
# ============================================================
