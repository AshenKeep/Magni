# ============================================================
# Magni v0.0.1 — environment configuration
# Copy to .env and fill in every value before running.
# Never commit .env to Git — it is in .gitignore.
# ============================================================

# --- App URL (HTTPS required) ---
# Full public URL your reverse proxy serves the app on.
# Must be https://. No trailing slash.
APP_URL=https://gym.yourdomain.com                  # CHANGE

# --- CORS ---
ALLOWED_ORIGINS=https://gym.yourdomain.com          # CHANGE

# --- PostgreSQL ---
POSTGRES_DB=magni
POSTGRES_USER=magni
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password      # CHANGE

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_redis_password             # CHANGE

# --- FastAPI ---
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_64_char_hex_string  # CHANGE
ENVIRONMENT=production

# --- Port exposed to host (reverse proxy points here) ---
BACKEND_PORT=8000

# --- Timezone (used by backup scheduler) ---
# Examples: Australia/Perth, Europe/London, America/New_York
TZ=UTC                                              # CHANGE

# --- Backup (CIFS NAS share) ---
# The backup volume mounts this CIFS path and writes daily pg_dump files to it.
# Cron schedule format: minute hour day month weekday
# Default: 2am every day
BACKUP_SCHEDULE=0 2 * * *
BACKUP_DIR=/backups

CIFS_PATH=//YOUR_NAS_IP/backups                     # CHANGE
CIFS_USERNAME=your_nas_username                     # CHANGE
CIFS_PASSWORD=your_nas_password                     # CHANGE
